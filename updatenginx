#!/usr/bin/env python3
import sys
import subprocess

config_path = '/etc/nginx/sites-available/imparatorluk'

try:
    with open(config_path, 'r') as f:
        content = f.read()
except Exception as e:
    print(f"Error reading nginx config: {e}")
    sys.exit(1)

# Check if /api-backend/ is already configured
if '/api-backend/' in content:
    print("Nginx is already configured with /api-backend/.")
    sys.exit(0)

# We want to insert the location block right before 'location / {'
nginx_rule = """
    location /api-backend/ {
        proxy_pass http://localhost:3003/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
"""

if 'location / {' in content:
    new_content = content.replace('location / {', nginx_rule + '\n    location / {', 1)
else:
    print("Error: Could not find 'location / {' inside Nginx config file.")
    sys.exit(1)

try:
    with open(config_path, 'w') as f:
        f.write(new_content)
    print("Nginx config updated successfully.")
except Exception as e:
    print(f"Error writing Nginx config: {e}")
    sys.exit(1)

# Test and reload Nginx
test_res = subprocess.run(['nginx', '-t'], capture_output=True, text=True)
if test_res.returncode != 0:
    print("Nginx syntax check failed. Reverting...")
    # Revert config
    with open(config_path, 'w') as f:
        f.write(content)
    print(test_res.stderr)
    sys.exit(1)

subprocess.run(['systemctl', 'reload', 'nginx'])
print("Nginx reloaded successfully!")
