#!/bin/bash
echo "=== 1. PM2 Status ==="
pm2 status

echo "=== 2. PM2 Logs (Last 50 lines) ==="
pm2 logs openfront --lines 50 --no-daemon || true

echo "=== 3. Listening Ports ==="
if command -v ss &> /dev/null; then
    ss -tulnp | grep -E "3000|3001|3002|nginx" || true
elif command -v netstat &> /dev/null; then
    netstat -tulnp | grep -E "3000|3001|3002|nginx" || true
else
    echo "Neither ss nor netstat found"
fi

echo "=== 4. Testing local port 3000 response ==="
curl -i http://127.0.0.1:3000/api/health || true
